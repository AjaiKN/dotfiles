# See https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = tab
# indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
# max_line_length = 80
spelling_language = en-US

[{*.{el,eld,lisp,scm,rkt,fnl,clj,cljs,cljr,cljc,cljd,edn,elm,ml,mli},.sbclrc}]
indent_style = space
[*.{py,fish,zig,rs,kt,kts,ktm}]
indent_style = space
indent_size = 4

[*.{roc,nix,json,yml,kdl,swift,lua,go,org,toml}]
indent_style = unset

[*.md]
trim_trailing_whitespace = false

[{vendor,config/zsh/plugins}/**/*]
indent_style = unset
indent_size = unset
end_of_line = unset
charset = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
max_line_length = unset
spelling_language = unset

[Makefile]
indent_style = tab
